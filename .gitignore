@'
# Dependencies
/node_modules

# Logs
*.log
npm-debug.log*
yarn-error.log

# Next.js build output
/.next/
/out/

# Firebase
.firebase/

# Terraform
/terraform/.terraform/
/terraform/*.tfstate
/terraform/*.tfstate.*
/terraform/crash.log
/terraform/*.tfvars
/terraform/override.tf
/terraform/override.tf.json
/terraform/*_override.tf
/terraform/*_override.tf.json
# The .terraform.lock.hcl file is a dependency lock file for Terraform providers.
# It's often recommended to commit it to version control to ensure consistent provider
# versions across all environments. Uncomment the line below if you want to ignore it.
# /terraform/.terraform.lock.hcl

# Build artifacts & temp files
/project_snapshot.txt
/file_list.txt
/npm
/terraform/terraform.exe

# Environment variables
.env
.env.*.local

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
'@ | Set-Content -Path "c:\schv1\.gitignore" -Encoding utf8
