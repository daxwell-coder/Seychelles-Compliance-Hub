{
  "description": "Event schema registry for schv1 compliance platform. Contains all event types and their JSON schema definitions.",
  "version": 1,
  "schemas": {
    "regulatory.change.ingested": {
      "type": "object",
      "properties": {
        "source_uri": { "type": "string" },
        "hash": { "type": "string" },
        "jurisdiction": { "type": "string" }
      },
      "required": ["source_uri", "hash", "jurisdiction"]
    },
    "regulatory.impact.assessed": {
      "type": "object",
      "properties": {
        "change_event_id": { "type": "string" },
        "impacted_obligation_ids": { "type": "array", "items": { "type": "string" } },
        "impact_level": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
        "rationale_ref": { "type": "string" },
        "classifier_version": { "type": "string" },
        "classifier_hash": { "type": "string" }
      },
      "required": ["change_event_id", "impacted_obligation_ids", "impact_level", "rationale_ref", "classifier_version", "classifier_hash"]
    },
    "task.created": {
      "type": "object",
      "properties": {
        "task_id": { "type": "string" },
        "status": { "type": "string", "enum": ["OPEN"] },
        "origin": { "type": "string" },
        "correlation_id": { "type": "string" }
      },
      "required": ["task_id", "status", "origin", "correlation_id"]
    },
    "task.status.changed": {
      "type": "object",
      "properties": {
        "task_id": { "type": "string" },
        "previous_status": { "type": "string" },
        "new_status": { "type": "string" },
        "changed_by": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["task_id", "previous_status", "new_status", "changed_by", "timestamp"]
    },
    "task.escalated": {
      "type": "object",
      "properties": {
        "task_id": { "type": "string" },
        "escalation_level": { "type": "string" },
        "reason": { "type": "string" }
      },
      "required": ["task_id", "escalation_level", "reason"]
    },
    "task.closed": {
      "type": "object",
      "properties": {
        "task_id": { "type": "string" },
        "closed_by": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["task_id", "closed_by", "timestamp"]
    },
    "envelope.v1": {
      "type": "object",
      "properties": {
        "envelope_version": { "type": "integer" },
        "producer": { "type": "string" },
        "correlation_id": { "type": "string" },
        "tenant_id": { "type": ["string", "null"] },
        "occurred_at": { "type": "string", "format": "date-time" },
        "emitted_at": { "type": "string", "format": "date-time" }
      },
      "required": ["envelope_version", "producer", "correlation_id", "occurred_at", "emitted_at"]
    }
  }
}
